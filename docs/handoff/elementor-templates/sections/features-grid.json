{
  "version": "0.4",
  "title": "Features — 3-Column Grid (Linear-inspired)",
  "type": "section",
  "description": "Showcase 3-6 key features in a responsive grid. Icon + title + description. Dark-mode friendly with Nordover tokens.",
  "elements": [
    {
      "id": "features-section",
      "elType": "section",
      "settings": {
        "_title": "Features Grid Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "features-container",
          "elType": "container",
          "settings": {
            "_title": "Features Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "48"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "features-header",
              "elType": "container",
              "settings": {
                "_title": "Section Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center",
                "text_align": "center",
                "max_width": {
                  "unit": "px",
                  "size": "600"
                },
                "margin": {
                  "unit": "px",
                  "top": "0",
                  "right": "auto",
                  "bottom": "0",
                  "left": "auto"
                }
              },
              "elements": [
                {
                  "id": "features-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Features Title",
                    "title": "Powerful Features",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "text_color": "var(--color-fg)"
                  }
                },
                {
                  "id": "features-desc",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "_title": "Features Description",
                    "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); margin: 0;\">Everything you need to build and ship faster.</p>"
                  }
                }
              ]
            },
            {
              "id": "features-grid",
              "elType": "container",
              "settings": {
                "_title": "Features Grid",
                "layout": "grid",
                "grid_columns": {
                  "size": "3",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "32"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "feature-1",
                  "elType": "container",
                  "settings": {
                    "_title": "Feature Card 1",
                    "layout": "flex",
                    "flex_direction": "column",
                    "gap": {
                      "unit": "px",
                      "size": "16"
                    },
                    "background_background": "classic",
                    "background_color": "var(--color-surface)",
                    "border_border": "solid",
                    "border_width": {
                      "unit": "px",
                      "top": "1",
                      "right": "1",
                      "bottom": "1",
                      "left": "1",
                      "isLinked": true
                    },
                    "border_color": "var(--color-border)",
                    "border_radius": {
                      "unit": "px",
                      "top": "12",
                      "right": "12",
                      "bottom": "12",
                      "left": "12",
                      "isLinked": true
                    },
                    "padding": {
                      "unit": "px",
                      "top": "32",
                      "right": "32",
                      "bottom": "32",
                      "left": "32",
                      "isLinked": false
                    }
                  },
                  "elements": [
                    {
                      "id": "feature-icon-1",
                      "elType": "widget",
                      "widgetType": "icon",
                      "settings": {
                        "_title": "Feature Icon",
                        "icon": "fas fa-bolt",
                        "icon_color": "var(--color-accent)",
                        "icon_size": {
                          "unit": "px",
                          "size": "32"
                        }
                      }
                    },
                    {
                      "id": "feature-title-1",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "_title": "Feature Title",
                        "title": "Lightning Fast",
                        "header_size": "h3",
                        "html_tag": "h3",
                        "typography_font_size": {
                          "unit": "px",
                          "size": "20"
                        },
                        "text_color": "var(--color-fg)"
                      }
                    },
                    {
                      "id": "feature-desc-1",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Feature Description",
                        "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); margin: 0;\">Optimized for performance. Load times under 50ms with zero dependencies.</p>"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
