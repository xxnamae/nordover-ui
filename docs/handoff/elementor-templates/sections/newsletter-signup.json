{
  "version": "0.4",
  "title": "Newsletter — Email Signup",
  "type": "section",
  "description": "Email newsletter subscription section. Headline, description, input field, submit button. Dark/light variants.",
  "elements": [
    {
      "id": "newsletter-section",
      "elType": "section",
      "settings": {
        "_title": "Newsletter Section",
        "background_background": "classic",
        "background_color": "var(--color-surface)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "40",
          "bottom": "80",
          "left": "40",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "newsletter-container",
          "elType": "container",
          "settings": {
            "_title": "Newsletter Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "32"
            },
            "max_width": {
              "unit": "px",
              "size": "600"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            },
            "align_items_flex_start": "center",
            "justify_content_flex_start": "center",
            "text_align": "center"
          },
          "elements": [
            {
              "id": "newsletter-headline",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "_title": "Newsletter Headline",
                "title": "Subscribe to Our Newsletter",
                "header_size": "h2",
                "html_tag": "h2",
                "typography_font_size": {
                  "unit": "px",
                  "size": "36"
                },
                "text_color": "var(--color-fg)"
              }
            },
            {
              "id": "newsletter-description",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "_title": "Newsletter Description",
                "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); margin: 0;\">Get weekly updates on design systems, no spam.</p>"
              }
            },
            {
              "id": "newsletter-form",
              "elType": "container",
              "settings": {
                "_title": "Email Form",
                "layout": "flex",
                "flex_direction": "row",
                "gap": {
                  "unit": "px",
                  "size": "8"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "newsletter-input",
                  "elType": "widget",
                  "widgetType": "form",
                  "settings": {
                    "_title": "Email Input",
                    "form_name": "newsletter_signup",
                    "form_fields": [
                      {
                        "field_type": "email",
                        "field_label": "Email",
                        "field_value": "",
                        "required": "yes",
                        "placeholder": "Your email"
                      }
                    ],
                    "form_button_text": "Subscribe",
                    "form_button_custom_class": "btn btn-primary"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
