{
  "version": "0.4",
  "title": "Stats — KPI Counters",
  "type": "section",
  "description": "Key performance indicators with numbers and labels. Grid layout with optional icons.",
  "elements": [
    {
      "id": "stats-section",
      "elType": "section",
      "settings": {
        "_title": "Stats Section",
        "background_background": "classic",
        "background_color": "var(--color-surface)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "stats-container",
          "elType": "container",
          "settings": {
            "_title": "Stats Container",
            "layout": "grid",
            "grid_columns": {
              "size": "4",
              "unit": ""
            },
            "gap": {
              "unit": "px",
              "size": "48"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "stat-item-1",
              "elType": "container",
              "settings": {
                "_title": "Stat Item",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "8"
                },
                "align_items_flex_start": "flex-start",
                "justify_content_flex_start": "flex-start",
                "text_align": "left"
              },
              "elements": [
                {
                  "id": "stat-number",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Stat Number",
                    "title": "250K+",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "typography_font_weight": "700",
                    "text_color": "var(--color-accent)"
                  }
                },
                {
                  "id": "stat-label",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "_title": "Stat Label",
                    "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-fg); margin: 0;\">Users Worldwide</p>"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
