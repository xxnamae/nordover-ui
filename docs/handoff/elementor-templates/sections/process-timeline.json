{
  "version": "0.4",
  "title": "Process — Timeline Steps",
  "type": "section",
  "description": "Step-by-step process or workflow timeline. 4-step layout with numbers and descriptions.",
  "elements": [
    {
      "id": "process-section",
      "elType": "section",
      "settings": {
        "_title": "Process Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "process-container",
          "elType": "container",
          "settings": {
            "_title": "Process Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            },
            "align_items_flex_start": "center",
            "justify_content_flex_start": "center"
          },
          "elements": [
            {
              "id": "process-header",
              "elType": "container",
              "settings": {
                "_title": "Process Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center",
                "text_align": "center",
                "max_width": {
                  "unit": "px",
                  "size": "600"
                }
              },
              "elements": [
                {
                  "id": "process-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Process Title",
                    "title": "How It Works",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "text_color": "var(--color-fg)"
                  }
                }
              ]
            },
            {
              "id": "process-steps",
              "elType": "container",
              "settings": {
                "_title": "Process Steps",
                "layout": "grid",
                "grid_columns": {
                  "size": "4",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "32"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "process-step-1",
                  "elType": "container",
                  "settings": {
                    "_title": "Process Step 1",
                    "layout": "flex",
                    "flex_direction": "column",
                    "gap": {
                      "unit": "px",
                      "size": "16"
                    },
                    "align_items_flex_start": "center",
                    "justify_content_flex_start": "flex-start",
                    "text_align": "center"
                  },
                  "elements": [
                    {
                      "id": "step-number",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "_title": "Step Number",
                        "title": "01",
                        "header_size": "h2",
                        "html_tag": "h2",
                        "typography_font_size": {
                          "unit": "px",
                          "size": "56"
                        },
                        "typography_font_weight": "700",
                        "text_color": "var(--color-accent)"
                      }
                    },
                    {
                      "id": "step-title",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "_title": "Step Title",
                        "title": "Choose Your Plan",
                        "header_size": "h3",
                        "html_tag": "h3",
                        "typography_font_size": {
                          "unit": "px",
                          "size": "20"
                        },
                        "text_color": "var(--color-fg)"
                      }
                    },
                    {
                      "id": "step-description",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Step Description",
                        "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); margin: 0;\">Select the plan that best fits your needs.</p>"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
