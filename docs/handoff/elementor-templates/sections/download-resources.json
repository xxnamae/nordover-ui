{
  "version": "0.4",
  "title": "Download — Resources & Assets",
  "type": "section",
  "description": "Downloadable resources grid with icon, title, description, and download/view button per resource.",
  "elements": [
    {
      "id": "download-section",
      "elType": "section",
      "settings": {
        "_title": "Download Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "download-container",
          "elType": "container",
          "settings": {
            "_title": "Download Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "download-header",
              "elType": "container",
              "settings": {
                "_title": "Download Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center",
                "text_align": "center",
                "max_width": {
                  "unit": "px",
                  "size": "600"
                }
              },
              "elements": [
                {
                  "id": "download-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Download Title",
                    "title": "Resources & Assets",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "text_color": "var(--color-fg)"
                  }
                },
                {
                  "id": "download-description",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "_title": "Download Description",
                    "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); margin: 0;\">Download design files, component libraries, and documentation to get started.</p>"
                  }
                }
              ]
            },
            {
              "id": "download-grid",
              "elType": "container",
              "settings": {
                "_title": "Download Grid",
                "layout": "grid",
                "grid_columns": {
                  "size": "3",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "32"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "download-card-1",
                  "elType": "container",
                  "settings": {
                    "_title": "Download Card 1",
                    "layout": "flex",
                    "flex_direction": "column",
                    "gap": {
                      "unit": "px",
                      "size": "16"
                    },
                    "align_items_flex_start": "flex-start",
                    "justify_content_flex_start": "flex-start",
                    "padding": {
                      "unit": "px",
                      "top": "32",
                      "right": "32",
                      "bottom": "32",
                      "left": "32",
                      "isLinked": false
                    },
                    "border_border": "solid",
                    "border_width": {
                      "unit": "px",
                      "top": "1",
                      "right": "1",
                      "bottom": "1",
                      "left": "1"
                    },
                    "border_color": "var(--color-border)",
                    "border_radius": {
                      "unit": "px",
                      "top": "8",
                      "right": "8",
                      "bottom": "8",
                      "left": "8"
                    },
                    "background_background": "classic",
                    "background_color": "var(--color-surface)"
                  },
                  "elements": [
                    {
                      "id": "download-icon-1",
                      "elType": "widget",
                      "widgetType": "icon",
                      "settings": {
                        "_title": "Download Icon",
                        "icon": "fas fa-file-pdf",
                        "icon_color": "var(--color-accent)",
                        "icon_size": {
                          "unit": "px",
                          "size": "48"
                        }
                      }
                    },
                    {
                      "id": "download-name-1",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "_title": "Resource Name",
                        "title": "Design Guide",
                        "header_size": "h3",
                        "html_tag": "h3",
                        "typography_font_size": {
                          "unit": "px",
                          "size": "18"
                        },
                        "text_color": "var(--color-fg)"
                      }
                    },
                    {
                      "id": "download-desc-1",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Resource Description",
                        "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); margin: 0;\">Complete design system specification including tokens, components, and usage patterns.</p>"
                      }
                    },
                    {
                      "id": "download-button-1",
                      "elType": "widget",
                      "widgetType": "button",
                      "settings": {
                        "_title": "Download Button",
                        "text": "Download PDF",
                        "link": {
                          "url": "#"
                        },
                        "button_type": "secondary",
                        "size": "sm",
                        "custom_class": "btn btn-secondary"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
