{
  "version": "0.4",
  "title": "Gallery — Image Grid with Lightbox",
  "type": "section",
  "description": "Image gallery with responsive grid and lightbox. 4-column on desktop, responsive on mobile.",
  "elements": [
    {
      "id": "gallery-section",
      "elType": "section",
      "settings": {
        "_title": "Gallery Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "gallery-container",
          "elType": "container",
          "settings": {
            "_title": "Gallery Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "gallery-header",
              "elType": "container",
              "settings": {
                "_title": "Gallery Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center",
                "text_align": "center",
                "max_width": {
                  "unit": "px",
                  "size": "600"
                },
                "margin": {
                  "unit": "px",
                  "top": "0",
                  "right": "auto",
                  "bottom": "0",
                  "left": "auto"
                }
              },
              "elements": [
                {
                  "id": "gallery-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Gallery Title",
                    "title": "Our Work",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "text_color": "var(--color-fg)"
                  }
                }
              ]
            },
            {
              "id": "gallery-grid",
              "elType": "container",
              "settings": {
                "_title": "Image Grid",
                "layout": "grid",
                "grid_columns": {
                  "size": "4",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "gallery-item-1",
                  "elType": "widget",
                  "widgetType": "image-gallery",
                  "settings": {
                    "_title": "Gallery Item",
                    "gallery": [
                      {
                        "id": "",
                        "url": "https://via.placeholder.com/300x300",
                        "alt": "Gallery image 1"
                      }
                    ],
                    "gallery_link": "file",
                    "aspect_ratio": "1:1",
                    "link_to_lightbox": "yes"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
