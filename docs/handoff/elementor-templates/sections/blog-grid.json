{
  "version": "0.4",
  "title": "Blog — Recent Posts Grid",
  "type": "section",
  "description": "Display recent blog posts in a 3-column grid. Card-based layout with excerpt and read more link.",
  "elements": [
    {
      "id": "blog-section",
      "elType": "section",
      "settings": {
        "_title": "Blog Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "blog-container",
          "elType": "container",
          "settings": {
            "_title": "Blog Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "blog-header",
              "elType": "container",
              "settings": {
                "_title": "Blog Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "flex-start"
              },
              "elements": [
                {
                  "id": "blog-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Blog Title",
                    "title": "Latest Articles",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "40"
                    },
                    "text_color": "var(--color-fg)"
                  }
                }
              ]
            },
            {
              "id": "blog-grid",
              "elType": "container",
              "settings": {
                "_title": "Blog Posts Grid",
                "layout": "grid",
                "grid_columns": {
                  "size": "3",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "32"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "blog-post-card",
                  "elType": "container",
                  "settings": {
                    "_title": "Blog Post Card",
                    "layout": "flex",
                    "flex_direction": "column",
                    "gap": {
                      "unit": "px",
                      "size": "16"
                    },
                    "background_background": "classic",
                    "background_color": "var(--color-surface)",
                    "border_border": "solid",
                    "border_width": {
                      "unit": "px",
                      "top": "1",
                      "right": "1",
                      "bottom": "1",
                      "left": "1",
                      "isLinked": true
                    },
                    "border_color": "var(--color-border)",
                    "border_radius": {
                      "unit": "px",
                      "top": "12",
                      "right": "12",
                      "bottom": "12",
                      "left": "12",
                      "isLinked": true
                    },
                    "padding": {
                      "unit": "px",
                      "top": "0",
                      "right": "0",
                      "bottom": "0",
                      "left": "0",
                      "isLinked": false
                    },
                    "overflow": "hidden"
                  },
                  "elements": [
                    {
                      "id": "blog-image",
                      "elType": "widget",
                      "widgetType": "image",
                      "settings": {
                        "_title": "Blog Thumbnail",
                        "image": {
                          "url": "https://via.placeholder.com/400x200",
                          "id": "",
                          "size": "",
                          "sizes": {},
                          "source": "library"
                        },
                        "width": {
                          "unit": "%",
                          "size": "100"
                        },
                        "aspect_ratio": "16:9"
                      }
                    },
                    {
                      "id": "blog-content",
                      "elType": "container",
                      "settings": {
                        "_title": "Blog Content",
                        "layout": "flex",
                        "flex_direction": "column",
                        "gap": {
                          "unit": "px",
                          "size": "12"
                        },
                        "padding": {
                          "unit": "px",
                          "top": "24",
                          "right": "24",
                          "bottom": "24",
                          "left": "24",
                          "isLinked": false
                        }
                      },
                      "elements": [
                        {
                          "id": "blog-date",
                          "elType": "widget",
                          "widgetType": "text-editor",
                          "settings": {
                            "_title": "Post Date",
                            "editor": "<p class=\"t-body-xs\" style=\"color: var(--color-muted); margin: 0; text-transform: uppercase;\">Jun 12, 2026</p>"
                          }
                        },
                        {
                          "id": "blog-post-title",
                          "elType": "widget",
                          "widgetType": "heading",
                          "settings": {
                            "_title": "Post Title",
                            "title": "Introducing Nordover v3.0",
                            "header_size": "h3",
                            "html_tag": "h3",
                            "typography_font_size": {
                              "unit": "px",
                              "size": "20"
                            },
                            "text_color": "var(--color-fg)"
                          }
                        },
                        {
                          "id": "blog-excerpt",
                          "elType": "widget",
                          "widgetType": "text-editor",
                          "settings": {
                            "_title": "Post Excerpt",
                            "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); margin: 0;\">The latest version includes improved typography, new components, and global quality standards.</p>"
                          }
                        },
                        {
                          "id": "blog-read-more",
                          "elType": "widget",
                          "widgetType": "button",
                          "settings": {
                            "_title": "Read More",
                            "text": "Read Article →",
                            "link": {
                              "url": "#",
                              "is_external": false
                            },
                            "button_custom_attributes": "class=\"btn btn-ghost btn-sm\""
                          }
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
