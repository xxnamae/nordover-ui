{
  "version": "0.4",
  "title": "Hero — Classic (Headline + CTA)",
  "type": "section",
  "description": "Full-width hero section with headline, description, and call-to-action button. Responsive design with background image support.",
  "elements": [
    {
      "id": "hero-section-main",
      "elType": "section",
      "settings": {
        "_title": "Hero Section",
        "background_background": "classic",
        "background_color": {
          "url": "",
          "id": "",
          "size": "",
          "sizes": {},
          "source": "library"
        },
        "padding": {
          "unit": "px",
          "top": "120",
          "right": "20",
          "bottom": "120",
          "left": "20",
          "isLinked": false
        },
        "min_height": {
          "unit": "px",
          "size": "500"
        },
        "custom_height": "yes",
        "content_position": "center"
      },
      "elements": [
        {
          "id": "hero-inner",
          "elType": "container",
          "settings": {
            "_title": "Hero Content Container",
            "layout": "flex",
            "flex_direction": "column",
            "align_items_flex_start": "center",
            "justify_content_flex_start": "center",
            "gap": {
              "unit": "px",
              "size": "24"
            },
            "width": {
              "unit": "%",
              "size": "100"
            },
            "max_width": {
              "unit": "px",
              "size": "800"
            }
          },
          "elements": [
            {
              "id": "hero-eyebrow",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "_title": "Eyebrow text",
                "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.08em; margin: 0;\">Welcome to Nordover</p>"
              }
            },
            {
              "id": "hero-heading",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "_title": "Main Headline",
                "title": "Build Beautiful Websites Fast",
                "header_size": "h1",
                "alignment": "center",
                "html_tag": "h1",
                "typography_typography": "custom",
                "typography_font_size": {
                  "unit": "px",
                  "size": "56"
                },
                "typography_font_weight": "600",
                "typography_line_height": {
                  "unit": "em",
                  "size": "1.2"
                },
                "text_color": "var(--color-fg)"
              }
            },
            {
              "id": "hero-description",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "_title": "Description",
                "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); max-width: 600px; text-align: center; margin: 0;\">With Nordover design system and Elementor, create stunning customer websites with global quality standards in minutes.</p>"
              }
            },
            {
              "id": "hero-buttons",
              "elType": "container",
              "settings": {
                "_title": "Button Group",
                "layout": "flex",
                "flex_direction": "row",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center"
              },
              "elements": [
                {
                  "id": "hero-btn-primary",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "_title": "Primary CTA",
                    "button_type": "default",
                    "text": "Get Started",
                    "link": {
                      "url": "#",
                      "is_external": false,
                      "nofollow": false
                    },
                    "size": "lg",
                    "button_css_id": "hero-cta-primary",
                    "button_custom_attributes": "class=\"btn btn-primary\""
                  }
                },
                {
                  "id": "hero-btn-secondary",
                  "elType": "widget",
                  "widgetType": "button",
                  "settings": {
                    "_title": "Secondary CTA",
                    "button_type": "default",
                    "text": "Learn More",
                    "link": {
                      "url": "#",
                      "is_external": false,
                      "nofollow": false
                    },
                    "size": "lg",
                    "button_css_id": "hero-cta-secondary",
                    "button_custom_attributes": "class=\"btn btn-ghost\""
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
