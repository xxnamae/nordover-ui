{
  "version": "0.4",
  "title": "Testimonials — Social Proof Cards",
  "type": "section",
  "description": "Customer testimonial cards with quote, author name, role. Supports star ratings.",
  "elements": [
    {
      "id": "testimonials-section",
      "elType": "section",
      "settings": {
        "_title": "Testimonials Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "testimonials-container",
          "elType": "container",
          "settings": {
            "_title": "Testimonials Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "1200"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            },
            "align_items_flex_start": "center",
            "justify_content_flex_start": "center"
          },
          "elements": [
            {
              "id": "testimonials-header",
              "elType": "container",
              "settings": {
                "_title": "Testimonials Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "center",
                "justify_content_flex_start": "center",
                "text_align": "center",
                "max_width": {
                  "unit": "px",
                  "size": "600"
                }
              },
              "elements": [
                {
                  "id": "testimonials-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "Testimonials Title",
                    "title": "What Our Customers Say",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "48"
                    },
                    "text_color": "var(--color-fg)"
                  }
                },
                {
                  "id": "testimonials-desc",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "_title": "Testimonials Description",
                    "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); margin: 0;\">Trusted by design teams worldwide.</p>"
                  }
                }
              ]
            },
            {
              "id": "testimonials-grid",
              "elType": "container",
              "settings": {
                "_title": "Testimonials Grid",
                "layout": "grid",
                "grid_columns": {
                  "size": "3",
                  "unit": ""
                },
                "gap": {
                  "unit": "px",
                  "size": "32"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "testimonial-card-1",
                  "elType": "container",
                  "settings": {
                    "_title": "Testimonial Card",
                    "layout": "flex",
                    "flex_direction": "column",
                    "gap": {
                      "unit": "px",
                      "size": "16"
                    },
                    "background_background": "classic",
                    "background_color": "var(--color-surface)",
                    "border_border": "solid",
                    "border_width": {
                      "unit": "px",
                      "top": "1",
                      "right": "1",
                      "bottom": "1",
                      "left": "1",
                      "isLinked": true
                    },
                    "border_color": "var(--color-border)",
                    "border_radius": {
                      "unit": "px",
                      "top": "12",
                      "right": "12",
                      "bottom": "12",
                      "left": "12",
                      "isLinked": true
                    },
                    "padding": {
                      "unit": "px",
                      "top": "32",
                      "right": "32",
                      "bottom": "32",
                      "left": "32",
                      "isLinked": false
                    }
                  },
                  "elements": [
                    {
                      "id": "testimonial-rating",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Star Rating",
                        "editor": "<p style=\"margin: 0; color: var(--color-accent);\">★★★★★</p>"
                      }
                    },
                    {
                      "id": "testimonial-quote",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Quote",
                        "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-fg); margin: 0; font-style: italic;\">"Nordover transformed how we build interfaces. Our design consistency improved dramatically."</p>"
                      }
                    },
                    {
                      "id": "testimonial-author",
                      "elType": "widget",
                      "widgetType": "heading",
                      "settings": {
                        "_title": "Author Name",
                        "title": "Sarah Chen",
                        "header_size": "h4",
                        "html_tag": "h4",
                        "typography_font_size": {
                          "unit": "px",
                          "size": "16"
                        },
                        "text_color": "var(--color-fg)"
                      }
                    },
                    {
                      "id": "testimonial-role",
                      "elType": "widget",
                      "widgetType": "text-editor",
                      "settings": {
                        "_title": "Author Role",
                        "editor": "<p class=\"t-body-sm\" style=\"color: var(--color-muted); margin: 0;\">Design Director, TechCorp</p>"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
