{
  "version": "0.4",
  "title": "FAQ — Accordion (Minimal Design)",
  "type": "section",
  "description": "Frequently Asked Questions in an accordion layout. Clean, expandable. No JavaScript required (pure CSS).",
  "elements": [
    {
      "id": "faq-section",
      "elType": "section",
      "settings": {
        "_title": "FAQ Section",
        "background_background": "classic",
        "background_color": "var(--color-bg)",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "20",
          "bottom": "80",
          "left": "20",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "faq-container",
          "elType": "container",
          "settings": {
            "_title": "FAQ Container",
            "layout": "flex",
            "flex_direction": "column",
            "gap": {
              "unit": "px",
              "size": "64"
            },
            "max_width": {
              "unit": "px",
              "size": "800"
            },
            "margin": {
              "unit": "px",
              "top": "0",
              "right": "auto",
              "bottom": "0",
              "left": "auto"
            }
          },
          "elements": [
            {
              "id": "faq-header",
              "elType": "container",
              "settings": {
                "_title": "FAQ Header",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "16"
                },
                "align_items_flex_start": "flex-start",
                "justify_content_flex_start": "flex-start"
              },
              "elements": [
                {
                  "id": "faq-title",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "_title": "FAQ Title",
                    "title": "Frequently Asked Questions",
                    "header_size": "h2",
                    "html_tag": "h2",
                    "typography_font_size": {
                      "unit": "px",
                      "size": "40"
                    },
                    "text_color": "var(--color-fg)"
                  }
                },
                {
                  "id": "faq-desc",
                  "elType": "widget",
                  "widgetType": "text-editor",
                  "settings": {
                    "_title": "FAQ Description",
                    "editor": "<p class=\"t-body-lg\" style=\"color: var(--color-muted); margin: 0;\">Can't find the answer you're looking for? Contact our support team.</p>"
                  }
                }
              ]
            },
            {
              "id": "faq-items",
              "elType": "container",
              "settings": {
                "_title": "FAQ Items",
                "layout": "flex",
                "flex_direction": "column",
                "gap": {
                  "unit": "px",
                  "size": "12"
                },
                "width": {
                  "unit": "%",
                  "size": "100"
                }
              },
              "elements": [
                {
                  "id": "faq-item-1",
                  "elType": "widget",
                  "widgetType": "accordion",
                  "settings": {
                    "_title": "FAQ Item 1",
                    "toggle_label": "What is Nordover?",
                    "text_content": "Nordover is a universal design system with tokens and reusable components for web and app interfaces. It's built on modern design principles from Apple, Linear, and Material Design.",
                    "active_default": "yes"
                  }
                },
                {
                  "id": "faq-item-2",
                  "elType": "widget",
                  "widgetType": "accordion",
                  "settings": {
                    "_title": "FAQ Item 2",
                    "toggle_label": "How long does setup take?",
                    "text_content": "For Elementor v4, setup takes about 5 minutes. Import the Nordover Kit, then start building with our pre-made sections. For custom development, integration takes 30 minutes."
                  }
                },
                {
                  "id": "faq-item-3",
                  "elType": "widget",
                  "widgetType": "accordion",
                  "settings": {
                    "_title": "FAQ Item 3",
                    "toggle_label": "Is it accessible?",
                    "text_content": "Yes. Nordover meets WCAG 2.1 AA standards by default. All components have proper ARIA labels, keyboard navigation, and sufficient color contrast."
                  }
                },
                {
                  "id": "faq-item-4",
                  "elType": "widget",
                  "widgetType": "accordion",
                  "settings": {
                    "_title": "FAQ Item 4",
                    "toggle_label": "Can I customize colors?",
                    "text_content": "Absolutely. All colors are defined as CSS tokens. Change a single token value and it updates across your entire site. No CSS knowledge needed."
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
