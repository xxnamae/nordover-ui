{
  "version": "0.4",
  "title": "Global Widget — Button Primary",
  "type": "global-widget",
  "description": "Reusable primary button with full Nordover styling. Change link, text, and size without breaking design.",
  "global_widget": {
    "id": "btn-primary-widget",
    "elType": "widget",
    "widgetType": "button",
    "settings": {
      "_title": "Primary Button",
      "text": "Click Me",
      "link": {
        "url": "#"
      },
      "button_type": "primary",
      "size": "md",
      "align": "center",
      "custom_class": "btn btn-primary",
      "typography_font_size": {
        "unit": "px",
        "size": "14"
      },
      "typography_font_weight": "600",
      "padding": {
        "unit": "px",
        "top": "12",
        "right": "24",
        "bottom": "12",
        "left": "24",
        "isLinked": false
      },
      "border_radius": {
        "unit": "px",
        "top": "6",
        "right": "6",
        "bottom": "6",
        "left": "6"
      },
      "background_color": "var(--color-accent)",
      "text_color": "var(--color-bg)",
      "border_border": "none"
    }
  },
  "notes": "This global widget is linked to the primary button style. Update the button text and link URL in the editor. Colors and sizing automatically use Nordover tokens."
}
