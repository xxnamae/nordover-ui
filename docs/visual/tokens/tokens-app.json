      "$type": "gradient",
      "$value": "color-mix(in oklch, var(--color-bg) 75%, transparent)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-bg-strong": {
      "$type": "gradient",
      "$value": "color-mix(in oklch, var(--color-bg) 90%, transparent)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-blur": {
      "$type": "gradient",
      "$value": "blur(10px) saturate(180%)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-blur-strong": {
      "$type": "gradient",
      "$value": "blur(18px) saturate(180%)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-border": {
      "$type": "gradient",
      "$value": "var(--bw-thin) solid color-mix(in oklch, var(--color-border) 50%, transparent)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-highlight": {
      "$type": "gradient",
      "$value": "color-mix(in oklch, white 55%, transparent)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-sheen": {
      "$type": "gradient",
      "$value": "color-mix(in oklch, white 22%, transparent)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "glass-depth-shadow": {
      "$type": "gradient",
      "$value": "0 8px 32px -8px rgb(0 0 0 / 0.18), 0 2px 8px -4px rgb(0 0 0 / 0.12)",
      "$extensions": {
        "com.nordover.cssText": true
      }
    },
    "gradient-radial-accent": {
      "$type": "gradient",
      "$value": "radial-gradient( ellipse 80% 50% at 50% -20%, color-mix(in oklch, var(--color-accent) 8%, transparent), transparent 70% )",
      "$extensions": {
        "com.nordover.cssText": true
      }
    }
  },
  "breakpoint": {
    "mobile": {
      "$type": "dimension",
      "$value": {
        "value": 30.0,
        "unit": "rem"
      }
    },
    "tablet": {
      "$type": "dimension",
      "$value": {
        "value": 36.0,
        "unit": "rem"
      }
    },
    "desktop": {
      "$type": "dimension",
      "$value": {
        "value": 48.0,
        "unit": "rem"
      }
    },
    "wide": {
      "$type": "dimension",
      "$value": {
        "value": 60.0,
        "unit": "rem"
      }
    },
    "ultra": {
      "$type": "dimension",
      "$value": {
        "value": 80.0,
        "unit": "rem"
      }
    }
  }
}
