{
  "name": "@xxnamae/nordover-ui",
  "version": "1.3.0",
  "description": "Production-ready design system. 34 core components, WCAG AA accessible, dark mode, responsive. Pure CSS framework for web and app interfaces.",
  "license": "MIT",
  "author": "Eirik Foleide <eirikfoleide@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/xxnamae/nordover-ui"
  },
  "homepage": "https://xxnamae.github.io/nordover-ui/",
  "keywords": [
    "design-system",
    "css-framework",
    "components",
    "design-tokens",
    "dtcg",
    "wcag-aa",
    "accessibility",
    "dark-mode",
    "responsive-design",
    "web",
    "app"
  ],
  "files": [
    "docs/visual/tokens/tokens-web.css",
    "docs/visual/tokens/tokens-app.css",
    "docs/visual/tokens/tokens-web.json",
    "docs/visual/tokens/tokens-app.json",
    "docs/visual/components/components-web.css",
    "docs/visual/components/components-app.css",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "docs/visual/components/components-web.css",
  "style": "docs/visual/components/components-web.css",
  "exports": {
    ".": {
      "style": "./docs/visual/components/components-web.css"
    },
    "./tokens-web": "./docs/visual/tokens/tokens-web.css",
    "./tokens-app": "./docs/visual/tokens/tokens-app.css",
    "./tokens-web-json": "./docs/visual/tokens/tokens-web.json",
    "./tokens-app-json": "./docs/visual/tokens/tokens-app.json",
    "./components-web": "./docs/visual/components/components-web.css",
    "./components-app": "./docs/visual/components/components-app.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:tokens": "python3 scripts/build_tokens.py",
    "check:tokens": "python3 scripts/build_tokens.py --check",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
