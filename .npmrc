# NPM Registry Configuration for @xxnamae scope

# Authenticate with NPM
# Set via: npm set //registry.npmjs.org/:_authToken <your-token>
# Get token from: https://www.npmjs.com/settings/xxnamae/tokens

# Publish to public NPM registry
registry=https://registry.npmjs.org

# Ensure scoped packages are public by default
@xxnamae:registry=https://registry.npmjs.org

# Publishing options
always-auth=false
access=public

# Save exact versions (no caret/tilde)
save-exact=false

# Fail on missing peer dependencies
strict-peer-dependencies=false
